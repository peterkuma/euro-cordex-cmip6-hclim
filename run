#!/usr/bin/env bash
set -e
shopt -s nullglob

njobs=$(nproc)

task=$1

export PARALLEL=--no-notice

LISTS=(
	hclim_historical+ssp126
	hclim_historical+ssp370
	gcm_historical+ssp126
)

LISTS_MEAN=(
	hclim_historical+ssp126
)

LISTS_DIFF=(
    hclim_historical+ssp370
)

SUBTYPES=(
    period_season
    period_season_region
)

tmp=$(mktemp)
tmp_final=$(mktemp)
trap 'rm -- "$tmp" "$tmp_final"' EXIT

cmd () {
	echo $* >> "$tmp"
}

run () {
	# cat "$tmp"
	parallel -tuj "$njobs" < "$tmp"
	echo > "$tmp"
}

calc_stats () {
	local input=$1
	local list=$2
	local subtype=$3
	local out=$4
	mkdir -p "$out"
	for source in $(cat "sources/list/${list}"); do
		cmd bin/calc_stats "$subtype" "$input/$source" "$source" "$out"
	done
}

convert_png () {
	local dir=$1
	mkdir -p "$dir/png"
	for file in "$dir/"*.pdf; do
		cmd \
			convert \
			-density 600 \
			"$file" \
			"$dir/png/$(basename "${file%.pdf}").png"
	done
}

case "$task" in

"")
	cat <<EOF
Usage: run TASK

Tasks:

  source_links          Create source symlinks in the input directory.
  remap_landmask        Remap land mask to a 1x1 degree grid for GCM calculations.
  remap_obs             Remap observatiosn to a 1x1 degree grid for GCM calculations.
  ensemble              Create an model ensemble.
  calc_stats            Calculate statistics (dep: source_links, remap_landmask, remap_obs, ensemble).
  plot_map_mean         Plot maps for means (dep: calc_stats).
  plot_map_trend        Plot maps for linear trends (dep: calc_stats).
  plot_map_diff         Plot maps for differences between time periods (dep: calc_stats).
  plot_heatmap_mean     Plot heatmaps for means (dep: calc_stats).
  plot_heatmap_diff     Plot heatmaps for differences between time periods (dep: calc_stats).
  plot_boxplot          Plot boxplots with statistics (dep: calc_stats).
  plot_gcm_rcm_scatter  Plot GCM-RCM scatter plot for temperature and precipitation (dep: calc_stats).
  model_ranking         Calculate model ranking (dep: calc_stats).
  plot_ranking          Plot model ranking (dep: model_ranking).
  plot_timeseries       Plot time series (dep: calc_stats).
  plot_annual_cycle     Plot annual cycle (dep: calc_stats).
EOF
	;;

source_links)
	mkdir -p input/sources
	while read -r line; do
		items=($line)
		name=${items[0]}
		mkdir -p "input/sources/$name"
		for path in ${items[@]:1}; do
			for file in "$path"/*.nc; do
				if [ -e "$file" ]; then
					cmd ln -fs "$file" -t "input/sources/$name/"
				fi
			done
		done
	done < "sources/paths"
	;;

remap_landmask)
	mkdir -p data/landmask
	cmd cdo \
		remapbil,r360x180 \
		input/landmask/sftlf_EUR-12_ERA5_evaluation_r1i1p1f1_HCLIMcom-SMHI_HCLIM43-ALADIN_v1-r1_fx.nc \
	 	data/landmask/sftlf_EUR-12_ERA5_evaluation_r1i1p1f1_HCLIMcom-SMHI_HCLIM43-ALADIN_v1-r1_fx_1x1deg.nc
	;;

remap_obs)
	for obs in $(cat sources/list/obs); do
		mkdir -p "data/1deg/$obs"
		for file in "input/sources/$obs"/*; do
			cmd cdo \
				remapbil,r360x180 \
				"$file" \
				"data/1deg/$obs/$(basename "$file")"
		done
	done
	;;

ensemble)
	mkdir -p data/ensembles
    for list in "${LISTS[@]}"; do
        cmd bin/ensemble input/sources $(cat "sources/list/$list") data/ensembles
    done
	run
	for file in data/ensembles/*; do
		cmd ln -sf "../../data/ensembles/$(basename "$file")" -t input/sources
	done
	;;

calc_stats)
	for list in "${LISTS[@]}"; do
		for subtype in "${SUBTYPES[@]}"; do
			calc_stats input/sources "$list" "$subtype" data/stats/$list/$subtype
			input=$([[ $list = gcm_historical+ssp126 ]] \
				&& echo data/1deg || echo input/sources)
			calc_stats "$input" obs "$subtype" data/stats/$list/$subtype
		done
	done
	run
	for list in "${LISTS[@]}"; do
	    cmd bin/index "data/stats/$list/period_season"
		cmd bin/index "data/stats/$list/period_season_region"
	done
	;;

plot_map_mean)
	for list in "${LISTS_MEAN[@]}"; do
	    out=plot/map_mean/$list
		mkdir -p "$out"
		cmd bin/plot_map \
			mean \
			"data/stats/$list/period_season" \
			$(cat sources/list/{obs,"$list"}) \
			"$out"
	done
	;;

plot_map_trend)
	for list in "${LISTS_MEAN[@]}"; do
		out=plot/map_trend/$list
		mkdir -p "$out"
		cmd bin/plot_map \
			trend \
			"data/stats/$list/period_season" \
			$(cat sources/list/{obs,"${list}"}) \
			"$out"
	done
	;;

plot_map_diff)
	for list in "${LISTS_DIFF[@]}"; do
	    out=plot/map_diff/$list
		mkdir -p "$out"
		cmd bin/plot_map \
			diff \
			"data/stats/$list/period_season" \
			$(cat "sources/list/$list") \
			"$out"
	done
	;;

plot_heatmap_mean)
	mkdir -p plot/heatmap
	for list in "${LISTS_MEAN}"; do
    	cmd bin/plot_heatmap \
    	    mean \
    		"data/stats/$list/period_season_region" \
    		$(cat sources/list/{obs,"$list"}) \
    		"plot/heatmap/$list"
	done
    ;;

plot_heatmap_diff)
	mkdir -p plot/heatmap
     for list in "${LISTS_DIFF}"; do
       	cmd bin/plot_heatmap \
       	    diff \
      		"data/stats/$list/period_season_region" \
      		$(cat "sources/list/$list") \
      		"plot/heatmap/$list"
    done
    ;;

plot_boxplot)
	mkdir -p plot/boxplot
	cmd bin/plot_boxplot \
		data/stats/hclim_historical+ssp126/period_season_region \
		$(cat sources/list/{obs,hclim_historical+ssp126}) \
		1991 2020 \
		plot/boxplot
	mkdir -p plot/boxplot_relative
	cmd bin/plot_boxplot_relative \
		data/stats/hclim_historical+ssp126/period_season_region \
		$(cat sources/list/{obs,hclim_historical+ssp126}) \
		1991 2020 \
		plot/boxplot_relative
	;;

plot_gcm_rcm_scatter)
	mkdir -p plot
	cmd bin/plot_gcm_rcm_scatter \
		data/stats/{gcm_historical+ssp126,hclim_historical+ssp126}/period_season_region \
		$(cat sources/list/hclim_historical+ssp126) \
		1991 2020 \
		plot/gcm_rcm_scatter.pdf
	;;

model_ranking)
	mkdir -p data
	cmd bin/model_ranking \
		data/stats/hclim_historical+ssp126/period_season_region \
		$(cat sources/list/{obs,hclim_historical+ssp126}) \
		1991 2020 \
		data/model_ranking.nc
	;;

plot_ranking)
	mkdir -p plot
	cmd bin/plot_ranking data/model_ranking.nc plot/model_ranking.pdf
	;;

plot_timeseries)
    mkdir -p plot/timeseries
    cmd bin/plot_timeseries \
        data/stats/hclim_historical+ssp370/period_season_region \
        $(cat sources/list/hclim_historical+ssp370) \
        1991 2020 \
        1991 2100 \
        2071 2100 \
        plot/timeseries/hclim_historical+ssp370.pdf
    ;;

plot_annual_cycle)
	mkdir -p plot
	cmd bin/plot_annual_cycle \
		data/stats/hclim_historical+ssp370/period_season_region \
		$(cat sources/list/hclim_historical+ssp370) \
		1991 2020 \
		2071 2100 \
		plot/annual_cycle.pdf

*)
	echo "$0: unknown task \"$task\"" >&2
	exit 1

esac

run
